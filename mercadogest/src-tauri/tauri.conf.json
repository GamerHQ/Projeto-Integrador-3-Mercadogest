{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "mercadogest",
  "version": "2.10.1",
  "identifier": "br.com.mercadogest",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "mercadogest - Sistema de Gestão",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "devtools": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
